{
  "name": "infracost-claude-code-plugin",
  "version": "1.0.0",
  "description": "GitHub Action to set up Claude Code CLI",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint --ext .ts,.js --ignore-path .gitignore .",
    "prepare": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run lint && npm run prepare && npm run test",
    "format": "prettier --write 'src/**/*.{js,ts}'"
  },
  "keywords": [],
  "author": "Infracost",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^1.9.1",
    "@actions/exec": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^5.3.1",
    "@typescript-eslint/parser": "^5.38.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.1.0",
    "eslint-config-prettier": "^8.5.0",
    "prettier": "^2.4.1",
    "typescript": "^4.4.4"
  }
}
